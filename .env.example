# ============================================================
# Top Shine POS — متغيرات البيئة
# ============================================================

# ——— قاعدة البيانات — Railway ———
# Railway توفرها تلقائياً عند إضافة MySQL service
MYSQLHOST=your-mysql-host
MYSQLUSER=your-mysql-user
MYSQLPASSWORD=your-mysql-password
MYSQLDATABASE=topshine_db
MYSQLPORT=3306

# ——— إعدادات التطبيق ———
APP_NAME=Top Shine
APP_ENV=production
APP_URL=https://your-app.railway.app
PORT=80

# ——— الأمان ———
SESSION_SECURE=1
SESSION_HTTPONLY=1
SESSION_SAMESITE=Lax

# ——— المتجر ———
STORE_NAME_AR=توب شاين
STORE_NAME_EN=Top Shine
STORE_CURRENCY=SDG
STORE_TIMEZONE=+03:00

# ——— الإعدادات الإضافية ———
LOG_LEVEL=warning
DEBUG=0
